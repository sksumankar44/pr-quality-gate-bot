# =============================================================================
# PR QUALITY GATE BOT — CONFIGURATION
# Copy this file to ".env" and fill in the values you need.
# You only need to fill the sections for the integrations you actually use.
# =============================================================================

# ----- Server -----
PORT=3000
# Comma-separated. Controls how verbose logs are: debug | info | warn | error
LOG_LEVEL=info

# =============================================================================
# AI PROVIDER  (pick ONE as the default; the rest are optional fallbacks)
# AI_PROVIDER = gemini | groq | openai | claude
# Recommended FREE default: gemini  (also great & free/fast: groq)
# =============================================================================
AI_PROVIDER=gemini

# --- Google Gemini (FREE tier, recommended) ---
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Groq (FREE, very fast, runs open models like Llama 3.3) ---
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenAI (paid) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic Claude (paid, high quality) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# =============================================================================
# GITHUB  (works for company GitHub AND personal GitHub at the same time)
# Create a fine-grained or classic PAT with "repo" + "pull_request" write scope:
#   https://github.com/settings/tokens
# =============================================================================
GITHUB_ENABLED=true
GITHUB_TOKEN=
# Any random string. You set the SAME value in the GitHub webhook config.
GITHUB_WEBHOOK_SECRET=
# For GitHub Enterprise Server, set the API base (default is public github.com):
GITHUB_API_BASE=https://api.github.com

# =============================================================================
# GITLAB  (company GitLab — self-hosted or gitlab.com)
# Create a Personal/Project Access Token with "api" scope:
#   <your-gitlab>/-/profile/personal_access_tokens
# =============================================================================
GITLAB_ENABLED=false
GITLAB_TOKEN=
# Any random string. You set the SAME value as the webhook "Secret token".
GITLAB_WEBHOOK_SECRET=
# Your GitLab API base. For gitlab.com use the default below.
GITLAB_API_BASE=https://gitlab.com/api/v4

# =============================================================================
# JIRA  (optional — used to verify the ticket in the branch actually exists)
# If left blank, the bot still does a regex branch-name check, just no live lookup.
# Create an API token: https://id.atlassian.com/manage-profile/security/api-tokens
# =============================================================================
JIRA_ENABLED=false
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
# Regex used to detect a ticket id in the branch name. Default matches PROJ-123.
JIRA_TICKET_REGEX=[A-Z][A-Z0-9]+-\d+

# =============================================================================
# NOTIFICATIONS  (optional — you use Teams now; Slack is ready to switch on)
# NOTIFY_PROVIDER = teams | slack | none
# =============================================================================
NOTIFY_PROVIDER=none
# Microsoft Teams Incoming Webhook (or Power Automate workflow) URL:
TEAMS_WEBHOOK_URL=
# Slack Incoming Webhook URL:
SLACK_WEBHOOK_URL=

# =============================================================================
# BEHAVIOUR
# =============================================================================
# Skip reviewing diffs larger than this many characters (protects token limits).
MAX_DIFF_CHARS=60000
# Only review files matching these extensions (comma separated). Empty = all.
REVIEW_FILE_EXTENSIONS=
# Post a reminder comment when no Jira ticket is found in the branch name.
CHECK_JIRA_BRANCH=true
# Post a note when a PR/MR changes code but adds no test files.
CHECK_TESTS_ADDED=true
